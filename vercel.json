{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.4"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/css/(.*)",
            "dest": "/public/css/$1"
        },
        {
            "src": "/js/(.*)",
            "dest": "/public/js/$1"
        },
        {
            "src": "/images/(.*)",
            "dest": "/public/images/$1"
        },
        {
            "src": "/fonts/(.*)",
            "dest": "/public/fonts/$1"
        },
        {
            "src": "/vendors/(.*)",
            "dest": "/public/vendors/"
        },
        {
            "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "",

        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "VIEW_COMPILED_PATH": "/tmp/views",

        "CACHE_DRIVER": "array",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie",

        "MAIL_MAILER": "smtp",
        "MAIL_HOST": "sandbox.smtp.mailtrap.io",
        "MAIL_PORT": "2525",
        "MAIL_USERNAME": "47aab6e5bbcfd1",
        "MAIL_PASSWORD": "6170f65625ace5",
        "MAIL_ENCRYPTION": "null",
        "MAIL_FROM_ADDRESS": "muhammadhasfi15@gmail.com",
        "MAIL_FROM_NAME": "Donation App"
    },
    "outputDirectory": "public"
}
